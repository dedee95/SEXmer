#!/usr/bin/env bash

set -euo pipefail

SEXMER_VERSION="1.0.0"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"

usage() {
    cat <<'EOF_HELP'

SEXmer: A resource-efficient toolkit for sex determination region analysis using k-mers.

Usage: SEXmer <module> [options]

Modules:
dump      Generate filtered canonical k-mer dump files.
scan      Identify sex-specific and sex-biased k-mers.
reads     Extract reads containing sex-specific k-mers.
map       Map sex-specific k-mers or sex-specific reads.
assign    Assign sex using validated sex-specific markers.

Use SEXmer <module> -h for detailed each module usage.

EOF_HELP
}

error() {
    echo "[Error] $*" >&2
}

join_by() {
    local sep="$1"
    shift
    local out=""
    local item
    for item in "$@"; do
        if [[ -z "$out" ]]; then
            out="$item"
        else
            out="${out}${sep}${item}"
        fi
    done
    echo "$out"
}

check_dependencies() {
    local missing=()
    local bin
    local kmc_missing=0
    local bbmap_missing=0
    local py_missing=""

    for bin in kmc kmc_dump; do
        command -v "$bin" &>/dev/null || kmc_missing=1
    done
    [[ "$kmc_missing" -eq 1 ]] && missing+=("KMC")

    for bin in bbmap.sh bbduk.sh reformat.sh; do
        command -v "$bin" &>/dev/null || bbmap_missing=1
    done
    [[ "$bbmap_missing" -eq 1 ]] && missing+=("BBMAP")

    if ! command -v sort &>/dev/null || ! sort --version 2>/dev/null | grep -q 'GNU'; then
        missing+=("GNU sort")
    fi

    command -v gzip &>/dev/null || missing+=("gzip")
    command -v awk &>/dev/null || missing+=("awk")

    if command -v python3 &>/dev/null; then
        py_missing=$(python3 - <<'PYCHECK' 2>/dev/null || true
import importlib.util
mods = ["pandas", "numpy", "matplotlib", "scipy"]
missing = [m for m in mods if importlib.util.find_spec(m) is None]
if missing:
    print(", ".join(missing))
PYCHECK
)
        [[ -n "$py_missing" ]] && missing+=("Python packages: ${py_missing}")
    else
        missing+=("python3")
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        error "Missing dependencies: $(join_by ', ' "${missing[@]}")"
        exit 1
    fi
}

run_module() {
    local module="$1"
    shift

    local script="${SCRIPT_DIR}/SEXmer-${module}.sh"

    if [[ ! -f "$script" ]]; then
        error "Module script not found: $script"
        exit 1
    fi

    if [[ ! -x "$script" ]]; then
        error "Module script is not executable: $script"
        exit 1
    fi

    exec "$script" "$@"
}

if [[ $# -eq 0 ]]; then
    check_dependencies
    usage
    exit 0
fi

case "$1" in
    -h|--help)
        check_dependencies
        usage
        exit 0
        ;;
    -v|--version)
        echo "SEXmer ${SEXMER_VERSION}"
        exit 0
        ;;
    dump)
        shift
        run_module dump "$@"
        ;;
    scan)
        shift
        run_module scan "$@"
        ;;
    assign)
        shift
        run_module assign "$@"
        ;;
    map)
        shift
        run_module map "$@"
        ;;
    reads)
        shift
        run_module reads "$@"
        ;;
    *)
        error "Unknown module or option: $1"
        usage >&2
        exit 1
        ;;
esac
