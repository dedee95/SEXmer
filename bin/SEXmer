#!/usr/bin/env bash

set -euo pipefail

SEXMER_VERSION="1.0.0"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"

usage() {
    cat <<'EOF_HELP'

SEXmer: Resource-efficient toolkit for sex determination region analysis based on k-mers

Usage: SEXmer <module> <parameters>

Modules:
dump         Generate filtered canonical k-mer dump files.
scan         Identify sex-specific and sex-biased k-mers.
reads        Extract reads containing sex-specific k-mers.
map          Map sex-specific k-mers or sex-specific reads.
assign       Assign sex using validated sex-specific markers.

Use <module> -h for module usage.

EOF_HELP
}

error() {
    echo "[Error] $*" >&2
}

run_module() {
    local module="$1"
    shift

    local script="${SCRIPT_DIR}/SEXmer-${module}.sh"

    if [[ ! -f "$script" ]]; then
        error "Module script not found: $script"
        exit 1
    fi

    if [[ ! -x "$script" ]]; then
        error "Module script is not executable: $script"
        exit 1
    fi

    exec "$script" "$@"
}

if [[ $# -eq 0 ]]; then
    usage
    exit 0
fi

case "$1" in
    -h|--help)
        usage
        exit 0
        ;;
    -v|--version)
        echo "SEXmer ${SEXMER_VERSION}"
        exit 0
        ;;
    dump)
        shift
        run_module dump "$@"
        ;;
    scan)
        shift
        run_module scan "$@"
        ;;
    assign)
        shift
        run_module assign "$@"
        ;;
    map)
        shift
        run_module map "$@"
        ;;
    reads)
        shift
        run_module reads "$@"
        ;;
    *)
        error "Unknown module or option: $1"
        usage >&2
        exit 1
        ;;
esac
